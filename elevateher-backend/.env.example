# ElevateHer backend environment. Copy to `.env` and fill in real values.

# ── Server ──
NODE_ENV=development
PORT=5000

# ── Database (PostgreSQL) ──
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://elevateher:password@localhost:5432/elevateher"

# ── Auth (JWT) ──
# Use a long, random string (32+ chars) in production. Startup warns on weak secrets.
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ── Security / CORS ──
# Comma-separated allowlist of browser origins that may call the API. Leave empty in
# local dev to allow all origins; set it in production, e.g.:
#   CORS_ORIGIN=https://app.elevateher.example,https://elevateher.example
CORS_ORIGIN=
# Max JSON request body size (default 1mb).
JSON_BODY_LIMIT=1mb
# Rate limiting (defaults shown). Window is in ms; max is requests per window per IP.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=30
# Set when running behind a reverse proxy/load balancer so the real client IP is used
# (e.g. TRUST_PROXY=1 for a single proxy hop). Leave unset for direct exposure.
TRUST_PROXY=

# ── Payments (Razorpay) ──
# Optional: the server now boots without these (Razorpay initialises lazily).
# Required only when payment features are exercised. Use Test Mode keys in dev.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── ML service ──
# Base URL of the FastAPI ML service, and per-request timeout before falling back.
ML_SERVICE_URL=http://localhost:8000
ML_TIMEOUT_MS=20000
